# EchoBell Direct key from the end of https://hook.echobell.one/d/<key>
ECHOBELL_DIRECT_KEY=replace-me

# Recommended: send this value from UniFi as X-Webhook-Secret.
WEBHOOK_SECRET=replace-with-a-long-random-value

# active, time-sensitive, or calling
ECHOBELL_NOTIFICATION_TYPE=time-sensitive

# Optional URL opened when the notification is tapped.
ECHOBELL_EXTERNAL_LINK=

# Testing override: notify on every connection, including known clients.
ALWAYS_NOTIFY=false

# Optional but recommended: seed historical clients at startup so existing devices
# do not notify once after the first deployment.
UNIFI_HOST=https://unifi-console.example.test
UNIFI_API_KEY=replace-with-network-integration-key
UNIFI_SITE=default
UNIFI_VERIFY_SSL=true
